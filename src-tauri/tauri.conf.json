{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "out-dns",
  "version": "0.1.0",
  "identifier": "com.amirithm-dev.out-dns",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "fullscreen": false,
        "height": 300,
        "resizable": false,
        "title": "Out DNS",
        "width": 600,
        "center": true,
        "focus": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDJDMjg3OUJFNEEzNkVDNDEKUldSQjdEWkt2bmtvTEpVU250MTlsNUhyL0dMZG1lMmdyZWZkUnRRcndWbmx6cFlYR2pyeFE2ZHQK",
      "endpoints": [
        "https://github.com/amirithm-dev/out-dns/releases/latest/download/latest.json"
      ]
    }
  }
}

